# HallucinationGuard SDK Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# GOOGLE API (Gemini Integration)
# =============================================================================
# Your Google AI API key for Gemini model integration
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# =============================================================================
# LANGFUSE (Observability & Tracing)
# =============================================================================
# Public key for Langfuse cloud instance
# Get from: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...

# Secret key for Langfuse authentication
LANGFUSE_SECRET_KEY=sk-lf-...

# =============================================================================
# HALLUCINATIONGUARD SDK SETTINGS
# =============================================================================
# Default policy to load when Guard() is called without arguments
# Options: default, rag_strict, chatbot, no_prompt_check
HG_DEFAULT_POLICY=default

# Directory for JSONL trace logs
# Default: ~/.hallucination_guard/traces/
HG_TRACE_DIR=~/.hallucination_guard/traces/

# HuggingFace model cache directory
# Default: ~/.cache/huggingface/
HG_MODEL_CACHE=~/.cache/huggingface/

# Python logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
HG_LOG_LEVEL=WARNING

# Disable HHEM model loading for fast mode testing
# Set to 'true' to skip HHEM (uses heuristics + embeddings only)
HG_DISABLE_HHEM=false

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Flask debug mode for frontend development
FLASK_DEBUG=true

# Port for the testing frontend
PORT=5000

# =============================================================================
# OPTIONAL: ADVANCED SETTINGS
# =============================================================================
# Custom model cache size limit (in GB)
# HF_HUB_CACHE_SIZE=10

# Disable automatic model downloads
# HF_HUB_OFFLINE=0

# Custom transformers cache directory
# TRANSFORMERS_CACHE=~/.cache/huggingface/transformers/

# PyTorch CUDA settings (if using GPU)
# CUDA_VISIBLE_DEVICES=0
# TORCH_USE_CUDA_DSA=1

# Memory optimization
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# Disable specific validators for faster/safer operation
HG_DISABLE_EMBEDDING=false
HG_DISABLE_HHEM=true

# =============================================================================
# OPTIONAL: ADVANCED SETTINGS
# =============================================================================
# Custom model cache size limit (in GB)
# HF_HUB_CACHE_SIZE=10

# Disable automatic model downloads
# HF_HUB_OFFLINE=0

# Custom transformers cache directory
# TRANSFORMERS_CACHE=~/.cache/huggingface/transformers/

# PyTorch CUDA settings (if using GPU)
# CUDA_VISIBLE_DEVICES=0
# TORCH_USE_CUDA_DSA=1

# Memory optimization
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
